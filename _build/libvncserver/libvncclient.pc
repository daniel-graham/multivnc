prefix=/usr/local
exec_prefix=/usr/local
libdir=/usr/local/lib
includedir=/usr/local/include

Name: LibVNCClient
Description: A library for easy implementation of a VNC client.
Version: 0.9.15
Requires:
Requires.private:
Libs: -L${libdir} -lvncclient
Libs.private:  -lsasl2.tbd -lz.tbd -ljpeg.dylib -lssl.dylib -lcrypto.dylib
Cflags: -I${includedir}

